# Maintainer: Hewel

pkgname=jmsr
pkgver=1.3.1
pkgrel=1
pkgdesc='Jellyfin cast receiver that controls external MPV'
arch=('x86_64')
url='https://github.com/hewel/jmsr'
license=('MIT')
options=('!lto')
depends=(
  'webkit2gtk-4.1'
  'gtk3'
  'libayatana-appindicator'
  'librsvg'
  'mpv'
)
makedepends=(
  'bun'
  'git'
  'rust'
)
source=(
  "git+https://github.com/hewel/jmsr.git#tag=v$pkgver"
  'top.pigfun.jmsr.desktop'
)
sha256sums=(
  'SKIP'
  'fad7c84a15d92cefa357b4e2cf2c0877e0a97ae8da2114468d9f8c86a27bc98f'
)

build() {
  cd "$srcdir/$pkgname"

  bun install --frozen-lockfile
  bun tauri build --no-bundle --ci
}

package() {
  cd "$srcdir/$pkgname"

  install -Dm755 "src-tauri/target/release/jmsr" "$pkgdir/usr/bin/jmsr"
  install -Dm644 "$srcdir/top.pigfun.jmsr.desktop" \
    "$pkgdir/usr/share/applications/top.pigfun.jmsr.desktop"
  install -Dm644 "src-tauri/icons/128x128.png" \
    "$pkgdir/usr/share/icons/hicolor/128x128/apps/top.pigfun.jmsr.png"
  install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
