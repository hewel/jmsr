{
  "name": "jmsr",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.17"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "lint-staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "jellyfin:api:generate": "bun scripts/jellyfin-api.mjs generate",
    "jellyfin:api:update": "bun scripts/jellyfin-api.mjs update",
    "format": "oxfmt --write package.json tsconfig.json tests/tsconfig.json '*.config.{js,json,jsonc,mjs,ts}' 'src/**/*.{css,js,jsx,json,jsonc,ts,tsx}' 'tests/**/*.{js,jsx,json,jsonc,ts,tsx}' 'scripts/**/*.mjs' 'src-tauri/**/*.json'",
    "format:check": "oxfmt --check package.json tsconfig.json tests/tsconfig.json '*.config.{js,json,jsonc,mjs,ts}' 'src/**/*.{css,js,jsx,json,jsonc,ts,tsx}' 'tests/**/*.{js,jsx,json,jsonc,ts,tsx}' 'scripts/**/*.mjs' 'src-tauri/**/*.json'",
    "lint": "oxlint --deny-warnings --no-error-on-unmatched-pattern src tests scripts rsbuild.config.ts rstest.config.ts rstest.setup.ts lint-staged.config.mjs",
    "lint:fix": "oxlint --fix --deny-warnings --no-error-on-unmatched-pattern src tests scripts rsbuild.config.ts rstest.config.ts rstest.setup.ts lint-staged.config.mjs",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run rust:fmt:check && bun run rust:clippy",
    "test:all": "bun run test && bun run rust:test",
    "prepare": "husky",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@solid-devtools/overlay": "^0.33.5",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/solid-form": "^1.33.0",
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-router": "^1.170.16",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@vanilla-extract/css": "^1.20.1",
    "effect": "^4.0.0-beta.84",
    "lucide-solid": "^1.20.0",
    "solid-js": "^1.9.13",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.38.0",
    "@rsbuild/core": "^2.0.15",
    "@rsbuild/plugin-babel": "^1.2.1",
    "@rsbuild/plugin-solid": "^1.2.2",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "@rstest/core": "^0.10.5",
    "@tanstack/router-plugin": "^1.168.18",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@vanilla-extract/webpack-plugin": "^2.3.27",
    "autoprefixer": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3"
  }
}
