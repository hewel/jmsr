{
  "name": "jmsr",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.17"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "lint-staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "check": "biome check . && bun run typecheck && bun run rust:fmt:check && bun run rust:clippy",
    "test:all": "bun run test && bun run rust:test",
    "prepare": "husky",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.36.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/solid-form": "^1.32.0",
    "@tanstack/solid-query": "^5.100.11",
    "@tanstack/solid-router": "^1.170.5",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "effect": "4.0.0-beta.69",
    "lucide-solid": "^1.16.0",
    "solid-js": "^1.9.13",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@rsbuild/core": "^2.0.7",
    "@rsbuild/plugin-babel": "^1.1.2",
    "@rsbuild/plugin-solid": "^1.2.0",
    "@rstest/core": "^0.10.1",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.15",
    "typescript": "^6.0.3"
  }
}
